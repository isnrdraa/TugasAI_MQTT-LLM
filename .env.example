# Salin file ini menjadi ".env" lalu isi kredensial MQTT yang sebenarnya.
# JANGAN commit file ".env" (berisi kredensial asli) ke repository/publik manapun.

# --- Koneksi MQTT (HiveMQ Cloud, TLS) ---
MQTT_HOST=your-cluster-id.a03.euc1.aws.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=

# --- Topik MQTT yang direkam ---
MQTT_TOPIC_SUHU=tas_ai_surya_fsm_uksw/suhu
MQTT_TOPIC_KELEMBABAN=tas_ai_surya_fsm_uksw/kelembaban

# --- Perilaku recorder ---
# Interval penulisan data ke DB & CSV (detik). Sensor publish tiap 20 detik.
WRITE_INTERVAL_SECONDS=20
# Timezone untuk timestamp yang disimpan.
TIMEZONE=Asia/Jakarta

# --- Lokasi file output (relatif terhadap working directory) ---
DATA_DIR=data
LOG_DIR=logs

# --- Supabase (opsional: push tambahan, selain SQLite & CSV) ---
# Kosongkan SUPABASE_URL/SUPABASE_KEY untuk menonaktifkan push ke Supabase.
# Gunakan service_role key (Project Settings > API), bukan anon key, karena
# recorder berjalan di backend/VPS dan perlu insert tanpa terblokir RLS.
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_TABLE=sensor_data
SUPABASE_TIMEOUT_SECONDS=10
# Retry singkat untuk menutup gangguan jaringan sesaat (gangguan lebih lama
# ditangkap oleh reconcile timer, lihat mqtt-recorder-reconcile.timer).
SUPABASE_MAX_ATTEMPTS=3
SUPABASE_RETRY_BACKOFF_SECONDS=2
