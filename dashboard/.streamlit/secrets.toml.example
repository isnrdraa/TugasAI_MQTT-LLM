# Salin file ini menjadi "secrets.toml" (di folder yang sama) untuk pengembangan lokal.
# JANGAN commit "secrets.toml" ke git -- sudah di-gitignore.
# Saat deploy ke Streamlit Community Cloud, isi nilai yang sama lewat menu
# Settings > Secrets di dashboard Streamlit Cloud (bukan lewat file ini).

# --- Supabase (WAJIB pakai anon key, JANGAN PERNAH service_role di sini) ---
SUPABASE_URL = "https://xxxxx.supabase.co"
SUPABASE_ANON_KEY = "eyJ..."
SUPABASE_TABLE = "sensor_data"

# --- Groq API (komentator AI, gratis) ---
GROQ_API_KEY = "gsk_..."
GROQ_MODEL = "llama-3.1-8b-instant"

# --- Timezone tampilan ---
TIMEZONE = "Asia/Jakarta"

# --- MQTT (opsional, hanya dipakai kalau toggle "Mode real-time langsung" diaktifkan) ---
MQTT_HOST = "your-cluster-id.a03.euc1.aws.hivemq.cloud"
MQTT_PORT = 8883
MQTT_USERNAME = ""
MQTT_PASSWORD = ""
MQTT_TOPIC_SUHU = "tas_ai_surya_fsm_uksw/suhu"
MQTT_TOPIC_KELEMBABAN = "tas_ai_surya_fsm_uksw/kelembaban"
